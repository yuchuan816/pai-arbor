generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model ChatSession {
  id        String    @id @default(uuid())
  userId    String    @default("default") @map("user_id")
  title     String    @default("新对话")
  status    String    @default("active") // active | completed
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  messages  Message[]

  @@index([userId, status])
  @@map("chat_sessions")
}

model Message {
  id                 String      @id @default(uuid())
  sessionId          String      @map("session_id")
  role               String
  parts              Json
  isConsolidated     Boolean     @default(false) @map("is_consolidated")
  isDeleted          Boolean     @default(false) @map("is_deleted")
  consolidationJobId String?     @map("consolidation_job_id")
  createdAt          DateTime    @default(now()) @map("created_at")
  session            ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, isConsolidated])
  @@index([sessionId, isDeleted])
  @@index([consolidationJobId])
  @@map("messages")
}

model UserMemory {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  text      String   @db.Text
  type      String // preference | event | fact
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, isDeleted])
  @@map("user_memories")
}

model ConsolidationJob {
  id          String    @id @default(uuid())
  status      String    @default("pending") // pending | running | completed | failed
  progress    String    @default("等待开始...")
  error       String?   @db.Text
  result      Json?
  snapshot    Json? // 任务上下文 + 记忆整理大模型对话 rawPayload
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  @@index([startedAt])
  @@map("consolidation_jobs")
}

model File {
  id        String      @id @default(uuid())
  fileName  String      @map("file_name")
  ossKey    String      @map("oss_key") // 存储在 MinIO 中的唯一 Object Key
  fileSize  Int         @map("file_size")
  createdAt DateTime    @default(now()) @map("created_at")
  chunks    FileChunk[]

  @@map("files")
}

model FileChunk {
  id             String @id @default(uuid())
  fileId         String @map("file_id")
  chunkIndex     Int    @map("chunk_index") // 切片排序索引 (0, 1, 2...)
  contentPreview String @map("content_preview") @db.Text // 存储纯文本，用于兜底或普通展示
  file           File   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@map("file_chunks")
}
